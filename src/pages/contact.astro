---
import Base from '../layouts/Base.astro';
import ContactForm from '../components/ContactForm.tsx';
import { SITE, SOCIAL } from '../consts';
---

<Base title="Contact" description={`Get in touch with ${SITE.author}.`}>
  <div class="mx-auto max-w-2xl px-5 py-14">
    <p class="mono mb-3 text-sm text-accent">// contact</p>
    <h1 class="text-3xl font-medium">Get in touch</h1>
    <p class="mt-3 max-w-xl text-muted">
      Whether it’s about software, research, or a collaboration — drop me a line.
    </p>

    <div class="mt-10">
      <ContactForm client:load />
    </div>

    <div class="mt-10 flex flex-wrap gap-5">
      {
        SOCIAL.map((s) => (
          <a
            href={s.href}
            class="mono inline-flex items-center gap-2 text-sm text-muted transition-colors hover:text-accent"
            target={s.key === 'email' ? undefined : '_blank'}
            rel="noopener noreferrer"
          >
            <i class={s.icon} aria-hidden="true" /> {s.label}
          </a>
        ))
      }
    </div>
  </div>
</Base>
