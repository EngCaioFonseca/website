---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PublicationList, { type Pub } from '../components/PublicationList.tsx';
import { SITE } from '../consts';

const items: Pub[] = (await getCollection('publications')).map((p) => ({
  title: p.data.title,
  authors: p.data.authors,
  venue: p.data.venue,
  year: p.data.year,
  type: p.data.type,
  doi: p.data.doi,
  url: p.data.url,
  pdf: p.data.pdf,
  code: p.data.code,
  tags: p.data.tags,
}));
---

<Base title="Publications" description={`Peer-reviewed publications by ${SITE.author}.`}>
  <div class="mx-auto max-w-2xl px-5 py-14">
    <p class="mono mb-3 text-sm text-accent">// publications</p>
    <h1 class="text-3xl font-medium">Publications</h1>
    <p class="mt-3 max-w-xl text-muted">Peer-reviewed research, filterable by type.</p>

    <div class="mt-10">
      <PublicationList client:load items={items} />
    </div>
  </div>
</Base>
