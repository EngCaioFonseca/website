---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PublicationList, { type Pub } from '../components/PublicationList.tsx';
import { SITE } from '../consts';
import { EDUCATION, RESEARCH_INTERESTS } from '../data/experience';

const research = (await getCollection('projects'))
  .filter((p) => p.data.kind === 'research')
  .sort((a, b) => a.data.order - b.data.order);

const items: Pub[] = (await getCollection('publications')).map((p) => ({
  title: p.data.title,
  authors: p.data.authors,
  venue: p.data.venue,
  year: p.data.year,
  type: p.data.type,
  doi: p.data.doi,
  url: p.data.url,
  pdf: p.data.pdf,
  code: p.data.code,
  tags: p.data.tags,
}));
---

<Base
  title="Academic research"
  description={`Academic and research work of ${SITE.author} — molecular communications, computational neuroscience and more.`}
>
  <div class="mx-auto max-w-2xl px-5 py-14">
    <p class="mono mb-3 text-sm text-accent">// academic research</p>
    <h1 class="text-3xl font-medium">Academic research</h1>
    <p class="mt-3 max-w-xl text-muted">
      My research background — a PhD in molecular communications, plus work spanning
      computational neuroscience, signal processing and bioengineering.
    </p>

    <div class="mt-14">
      <SectionHeading index="01" title="Publications" />
      <PublicationList client:load items={items} />
    </div>

    {
      research.length > 0 && (
        <div class="mt-16">
          <SectionHeading index="02" title="Research projects" />
          <div class="space-y-4">
            {research.map((p) => (
              <div class="rounded-xl border border-border bg-surface p-5">
                <div class="flex items-center gap-2">
                  <i class="ti ti-flask text-accent" aria-hidden="true" />
                  <span class="font-medium">{p.data.title}</span>
                  {p.data.year && <span class="mono ml-auto text-[12px] text-faint">{p.data.year}</span>}
                </div>
                {p.data.role && <p class="mono mt-1 text-[12px] text-faint">{p.data.role}</p>}
                <p class="mt-2 text-sm text-muted">{p.data.description}</p>
                {p.data.url && (
                  <a
                    href={p.data.url}
                    class="mono mt-3 inline-block text-[12px] text-accent link-underline"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    learn more ↗
                  </a>
                )}
              </div>
            ))}
          </div>
        </div>
      )
    }

    <div class="mt-16">
      <SectionHeading index="03" title="Education" />
      <ul class="space-y-5">
        {
          EDUCATION.map((d) => (
            <li class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
              <div>
                <p class="font-medium">
                  {d.degree} · {d.field}
                </p>
                <p class="text-sm text-muted">
                  {d.org}
                  {d.location ? `, ${d.location}` : ''}
                </p>
              </div>
              <span class="mono shrink-0 text-[12px] text-faint">
                {d.start ? `${d.start}–${d.end}` : d.end}
              </span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="mt-16">
      <SectionHeading index="04" title="Research interests" />
      <div class="flex flex-wrap gap-2">
        {
          RESEARCH_INTERESTS.map((t) => (
            <span class="mono rounded-full border border-border px-3 py-1 text-[12px] text-muted">
              {t}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</Base>
