---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';
import AgentShell from '../components/AgentShell.tsx';
import BioNetCanvas from '../components/BioNetCanvas.tsx';
import LiveStatusStrip from '../components/LiveStatusStrip.tsx';
import GithubActivity from '../components/GithubActivity.tsx';
import ContributionGraph from '../components/ContributionGraph.astro';
import ResearchGraph from '../components/ResearchGraph.tsx';
import { SITE, SOCIAL } from '../consts';
import { fetchGitHubContributions } from '../utils/githubContributions';
import { buildSiteIndex } from '../utils/siteIndex';
import { buildResearchGraph } from '../utils/researchGraph';
import { withBase } from '../utils/url';

const githubContributions = await fetchGitHubContributions(SITE.githubUser);

const allProjects = await getCollection('projects');
const publications = await getCollection('publications');
const posts = await getCollection('posts');

const siteIndex = buildSiteIndex(allProjects, publications, posts);

const researchGraph = buildResearchGraph(
  publications,
  allProjects.filter((p) => p.data.kind === 'research'),
);

const projects = allProjects
  .filter((p) => p.data.featured && p.data.kind === 'software')
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const paperCount = publications.length;
const softwareCount = allProjects.filter((p) => p.data.kind === 'software').length;

const recentPosts = posts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Base>
  <section class="hero-cockpit">
    <BioNetCanvas client:idle />
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-scanline" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto max-w-5xl px-5 pb-0 pt-12 sm:pt-16">
      <div class="grid items-start gap-8 lg:grid-cols-[1fr_1.05fr] lg:gap-10">
        <div class="pt-1">
          <div class="hero-badge mb-5">
            <span class="status-live" aria-hidden="true"></span>
            agent shell · local index
          </div>
          <p class="mono mb-3 text-sm text-accent">// {SITE.role}</p>
          <h1 class="text-4xl font-medium leading-[1.06] tracking-tight sm:text-[2.75rem]">
            Hi, I’m Caio.
          </h1>
          <p class="mt-5 max-w-lg text-lg leading-relaxed text-muted">{SITE.description}</p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a
              href={withBase('/projects')}
              class="rounded-lg bg-accent-strong px-4 py-2 text-sm font-medium text-white transition-opacity hover:opacity-90"
            >
              View work →
            </a>
            <button
              type="button"
              data-cmdk
              class="rounded-lg border border-border-strong px-4 py-2 text-sm transition-colors hover:border-accent"
            >
              ⌘K palette
            </button>
            <a
              href={withBase('/contact')}
              class="rounded-lg border border-border px-4 py-2 text-sm text-muted transition-colors hover:border-border-strong hover:text-text"
            >
              Contact
            </a>
          </div>
          <div class="mt-7 flex gap-4">
            {
              SOCIAL.map((s) => (
                <a
                  href={s.href}
                  aria-label={s.label}
                  class="text-xl text-muted transition-colors hover:text-accent"
                  target={s.key === 'email' ? undefined : '_blank'}
                  rel="noopener noreferrer"
                >
                  <i class={s.icon} aria-hidden="true" />
                </a>
              ))
            }
          </div>
          <p class="mono mt-8 hidden text-[11px] text-faint sm:block">
            try in shell: <span class="text-muted">ask glioblastoma</span> ·
            <span class="text-muted"> papers</span> ·
            <span class="text-muted"> projects</span>
          </p>
        </div>
        <AgentShell client:load siteIndex={siteIndex} />
      </div>
    </div>

    <LiveStatusStrip
      client:idle
      githubUser={SITE.githubUser}
      contributions={githubContributions?.totalContributions}
      papers={paperCount}
      projects={softwareCount}
    />
  </section>

  <section class="mx-auto max-w-3xl px-5 py-14">
    <SectionHeading index="01" title="Selected work" href="/projects" cta="all projects" />
    <div class="grid gap-3 sm:grid-cols-2">
      {
        projects.map((p) => (
          <a
            href={p.data.url ?? p.data.repo ?? withBase('/projects')}
            class="group flex flex-col rounded-xl border border-border bg-surface p-4 transition-colors hover:border-border-strong"
            target={p.data.url || p.data.repo ? '_blank' : undefined}
            rel="noopener noreferrer"
          >
            <div class="flex items-center gap-2">
              <i class="ti ti-folder-code text-accent" aria-hidden="true" />
              <span class="font-medium transition-colors group-hover:text-accent">{p.data.title}</span>
              {p.data.year && <span class="mono ml-auto text-[12px] text-faint">{p.data.year}</span>}
            </div>
            <p class="mt-2 text-sm text-muted">{p.data.description}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 pb-14">
    <SectionHeading
      index="02"
      title="GitHub activity"
      href={`https://github.com/${SITE.githubUser}`}
      cta="view profile"
    />
    <div class="rounded-xl border border-border bg-surface p-5">
      {
        githubContributions ? (
          <ContributionGraph calendar={githubContributions} user={SITE.githubUser} />
        ) : (
          <p class="mb-4 border-b border-border pb-4 text-sm text-muted">
            Contribution calendar unavailable — view it on{' '}
            <a
              href={`https://github.com/${SITE.githubUser}`}
              class="text-accent link-underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub ↗
            </a>
            .
          </p>
        )
      }
      <GithubActivity client:idle user={SITE.githubUser} count={6} />
    </div>
  </section>

  {
    recentPosts.length > 0 && (
      <section class="mx-auto max-w-3xl px-5 pb-14">
        <SectionHeading index="03" title="Recent writing" href="/writing" cta="all posts" />
        <ul class="divide-y divide-border">
          {recentPosts.map((p) => (
            <li>
              <a
                href={withBase(`/writing/${p.id}/`)}
                class="group flex flex-col gap-1 py-4 sm:flex-row sm:items-baseline sm:justify-between"
              >
                <span class="font-medium transition-colors group-hover:text-accent">
                  {p.data.title}
                </span>
                <span class="mono shrink-0 text-[12px] text-faint">{fmtDate(p.data.date)}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <section class="mx-auto max-w-3xl px-5 pb-16">
    <SectionHeading
      index={recentPosts.length > 0 ? '04' : '03'}
      title="Research background"
      href="/academic#research-map"
      cta="full research map"
    />
    <div class="mb-4">
      <ResearchGraph client:visible data={researchGraph} height={240} compact />
    </div>
    <a
      href={withBase('/academic')}
      class="group flex flex-col gap-3 rounded-xl border border-border bg-surface p-5 transition-colors hover:border-border-strong sm:flex-row sm:items-center sm:justify-between"
    >
      <div class="flex items-start gap-3">
        <i class="ti ti-flask mt-0.5 text-xl text-accent" aria-hidden="true"></i>
        <div>
          <p class="font-medium transition-colors group-hover:text-accent">
            Before software, a PhD in molecular communications
          </p>
          <p class="mt-1 text-sm text-muted">
            {paperCount} peer-reviewed publications spanning molecular communications, EEG and
            computational neuroscience.
          </p>
        </div>
      </div>
      <span class="mono shrink-0 text-sm text-accent">explore →</span>
    </a>
  </section>
</Base>
