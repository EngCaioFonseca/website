---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';
import GithubRepos from '../components/GithubRepos.tsx';
import { SITE } from '../consts';
import { withBase } from '../utils/url';

const software = (await getCollection('projects'))
  .filter((p) => p.data.kind === 'software')
  .sort((a, b) => a.data.order - b.data.order);
---

<Base title="Projects" description={`Software projects built by ${SITE.author}.`}>
  <div class="mx-auto max-w-3xl px-5 py-14">
    <p class="mono mb-3 text-sm text-accent">// projects</p>
    <h1 class="text-3xl font-medium">Projects</h1>
    <p class="mt-3 max-w-xl text-muted">
      Software I’ve built. For research projects and publications, see{' '}
      <a href={withBase('/academic')} class="text-accent link-underline">academic research</a>.
    </p>

    {
      software.length > 0 && (
        <div class="mt-12">
          <SectionHeading index="01" title="Software" />
          <div class="grid gap-3 sm:grid-cols-2">
            {software.map((p) => (
              <a
                href={p.data.repo ?? p.data.url ?? '#'}
                class="group flex flex-col rounded-xl border border-border bg-surface p-4 transition-colors hover:border-border-strong"
                target={p.data.repo || p.data.url ? '_blank' : undefined}
                rel="noopener noreferrer"
              >
                <div class="flex items-center gap-2">
                  <i class="ti ti-folder-code text-accent" aria-hidden="true" />
                  <span class="font-medium transition-colors group-hover:text-accent">{p.data.title}</span>
                  {p.data.year && <span class="mono ml-auto text-[12px] text-faint">{p.data.year}</span>}
                </div>
                <p class="mt-2 flex-1 text-sm text-muted">{p.data.description}</p>
                {p.data.tags.length > 0 && (
                  <div class="mono mt-3 flex flex-wrap gap-2 text-[11px] text-faint">
                    {p.data.tags.map((t) => (
                      <span>#{t}</span>
                    ))}
                  </div>
                )}
              </a>
            ))}
          </div>
        </div>
      )
    }

    <div class="mt-12">
      <SectionHeading index="02" title="From GitHub" />
      <GithubRepos client:visible user={SITE.githubUser} count={6} />
    </div>
  </div>
</Base>
