---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { SITE } from '../../consts';
import { withBase } from '../../utils/url';

const posts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Base title="Writing" description={`Notes and essays by ${SITE.author}.`}>
  <div class="mx-auto max-w-2xl px-5 py-14">
    <p class="mono mb-3 text-sm text-accent">// writing</p>
    <h1 class="text-3xl font-medium">Writing</h1>
    <p class="mt-3 max-w-xl text-muted">
      Notes on what I build and the ideas I keep circling back to.
    </p>

    {posts.length === 0 && <p class="mt-10 text-muted">No posts yet — soon.</p>}

    <ul class="mt-10 divide-y divide-border">
      {
        posts.map((p) => (
          <li>
            <a href={withBase(`/writing/${p.id}/`)} class="group block py-5">
              <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
                <span class="font-medium transition-colors group-hover:text-accent">{p.data.title}</span>
                <span class="mono shrink-0 text-[12px] text-faint">{fmtDate(p.data.date)}</span>
              </div>
              <p class="mt-1 text-sm text-muted">{p.data.description}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</Base>
