---
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import { SITE } from '../consts';
import { withBase } from '../utils/url';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
}

const { title, description = SITE.description, image, article = false } = Astro.props;
const pageTitle = title ? `${title} · ${SITE.title}` : `${SITE.title} — ${SITE.role}`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// Per-route terminal-style OG image (generated by src/pages/og/[...route].ts).
const ogBase = import.meta.env.BASE_URL.replace(/\/$/, '');
let ogRel = Astro.url.pathname;
if (ogBase && ogRel.startsWith(ogBase)) ogRel = ogRel.slice(ogBase.length);
ogRel = ogRel.replace(/^\/+|\/+$/g, '');
const OG_PAGES = new Set(['home', 'about', 'experience', 'projects', 'academic', 'writing', 'contact']);
const ogSeg = ogRel.split('/')[0] || 'home';
const ogId = OG_PAGES.has(ogSeg) ? ogSeg : 'home';
const ogImage = new URL(image ?? withBase(`/og/${ogId}.png`), Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.author,
  url: SITE.url,
  jobTitle: SITE.role,
  email: `mailto:${SITE.email}`,
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3/dist/tabler-icons.min.css"
/>
<link rel="sitemap" href={withBase('/sitemap-index.xml')} />
<link
  rel="alternate"
  type="application/rss+xml"
  title={SITE.title}
  href={new URL(withBase('/rss.xml'), Astro.site)}
/>

<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta name="generator" content={Astro.generator} />

<meta property="og:type" content={article ? 'article' : 'website'} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content={SITE.title} />
<meta property="og:locale" content="en_US" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<meta name="theme-color" content="#fcfcfb" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#0d0d0c" media="(prefers-color-scheme: dark)" />

<script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
