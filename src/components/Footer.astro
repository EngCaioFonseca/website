---
import { SITE, SOCIAL, NAV } from '../consts';
import { withBase } from '../utils/url';
const year = new Date().getFullYear();
const links = NAV.filter((n) => n.href !== '/');
---

<footer class="mt-20 border-t border-border">
  <div class="mx-auto max-w-3xl px-5 py-10">
    <div class="flex flex-col gap-8 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <a href={withBase('/')} class="mono text-sm font-medium">caio<span class="text-accent">.</span>fonseca</a>
        <p class="mt-2 max-w-xs text-sm text-muted">{SITE.role}</p>
        <div class="mt-4 flex gap-4">
          {
            SOCIAL.map((s) => (
              <a
                href={s.href}
                aria-label={s.label}
                class="text-lg text-muted transition-colors hover:text-accent"
                target={s.key === 'email' ? undefined : '_blank'}
                rel="noopener noreferrer"
              >
                <i class={s.icon} aria-hidden="true" />
              </a>
            ))
          }
        </div>
      </div>

      <nav class="grid grid-cols-2 gap-x-10 gap-y-2" aria-label="Footer">
        {
          links.map((n) => (
            <a href={withBase(n.href)} class="mono text-sm text-muted transition-colors hover:text-accent">
              {n.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div class="mt-10 flex flex-col gap-1 border-t border-border pt-6 text-[12px] text-faint sm:flex-row sm:items-center sm:justify-between">
      <p class="mono">© {year} {SITE.author}</p>
      <p class="mono">built with astro · hosted on github pages</p>
    </div>
  </div>
</footer>
