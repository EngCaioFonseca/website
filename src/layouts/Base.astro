---
import { getCollection } from 'astro:content';
import { ClientRouter } from 'astro:transitions';
import BaseHead from '../components/BaseHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import CommandPalette from '../components/CommandPalette.tsx';
import { buildSiteIndex } from '../utils/siteIndex';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
}

const { title, description, image, article } = Astro.props;

const [projects, publications, posts] = await Promise.all([
  getCollection('projects'),
  getCollection('publications'),
  getCollection('posts'),
]);
const siteIndex = buildSiteIndex(projects, publications, posts);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} article={article} />
    <ClientRouter />
    <script is:inline>
      (function () {
        var ACCENTS = ['emerald', 'matrix', 'amber', 'cyan', 'violet'];
        function applyTheme() {
          var t = localStorage.getItem('theme');
          var d = t ? t === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.classList.toggle('dark', d);
        }
        function applyAccent() {
          var a = localStorage.getItem('accent') || 'emerald';
          if (ACCENTS.indexOf(a) === -1) a = 'emerald';
          document.documentElement.dataset.accent = a;
        }
        applyTheme();
        applyAccent();
        if (!window.__ui) {
          window.__ui = true;
          document.addEventListener('click', function (e) {
            if (e.target.closest('#theme-toggle')) {
              var d = document.documentElement.classList.toggle('dark');
              localStorage.setItem('theme', d ? 'dark' : 'light');
            } else if (e.target.closest('[data-cmdk]')) {
              window.dispatchEvent(new Event('cmdk:open'));
            } else if (e.target.closest('#menu-toggle')) {
              var m = document.getElementById('mobile-menu');
              if (m) m.classList.toggle('hidden');
            }
          });
          window.addEventListener('accent:set', function (e) {
            if (e.detail && ACCENTS.indexOf(e.detail) !== -1) {
              localStorage.setItem('accent', e.detail);
              applyAccent();
            }
          });
          window.addEventListener('accent:cycle', function () {
            var cur = localStorage.getItem('accent') || 'emerald';
            var i = (ACCENTS.indexOf(cur) + 1) % ACCENTS.length;
            localStorage.setItem('accent', ACCENTS[i < 0 ? 0 : i]);
            applyAccent();
          });
          document.addEventListener('astro:after-swap', function () {
            applyTheme();
            applyAccent();
            var m = document.getElementById('mobile-menu');
            if (m) m.classList.add('hidden');
          });
        }
      })();
    </script>
  </head>
  <body class="min-h-dvh">
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <CommandPalette client:idle siteIndex={siteIndex} />
    <Analytics />
  </body>
</html>
